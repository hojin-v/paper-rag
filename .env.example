PAPERRAG_RUNTIME_MODE=production
PAPERRAG_ALLOW_DEGRADED_RESULTS=false
PAPERRAG_ALLOW_DIAGNOSTIC_BACKENDS=false
PAPERRAG_DATABASE_URL=postgresql+psycopg://paperrag:paperrag@localhost:5432/paperrag
PAPERRAG_OLLAMA_BASE_URL=http://localhost:11434
PAPERRAG_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
PAPERRAG_LLM_TIMEOUT_SECONDS=300
PAPERRAG_LLM_TEMPERATURE=0.0
PAPERRAG_LLM_MAX_OUTPUT_TOKENS=192
PAPERRAG_LLM_CACHE_ENABLED=true
PAPERRAG_LLM_CACHE_DIR=./data/llm-cache
PAPERRAG_EMBED_BASE_URL=http://localhost:8100
PAPERRAG_EMBED_DIM=1024
PAPERRAG_EMBED_TIMEOUT_SECONDS=600
# 운영은 st만 사용한다. hash는 테스트 전용이며 실제 검색 품질이 없다.
PAPERRAG_EMBED_ENCODER=st
PAPERRAG_EMBED_MODEL_NAME=BAAI/bge-m3
PAPERRAG_DATA_DIR=./data
PAPERRAG_RESULT_DIR=./outputs
PAPERRAG_REVIEW_DIR=./data/review
PAPERRAG_REVIEW_DEFAULT_BACKEND=paddle
PAPERRAG_INGEST_BACKEND=paddle
PAPERRAG_REVIEW_MAX_UPLOAD_MB=100
PAPERRAG_REVIEW_RENDER_DPI=120
PAPERRAG_OCR_RENDER_DPI=200
PAPERRAG_PADDLEX_CACHE_DIR=./models/paddlex
PAPERRAG_PADDLEX_MODEL_SOURCE=bos
PAPERRAG_PADDLE_DEVICE=cpu
PAPERRAG_PADDLE_ENABLE_MKLDNN=false
PAPERRAG_PADDLE_ISOLATE_PROCESS=true
PAPERRAG_PADDLE_WORKER_TIMEOUT_SECONDS=1800
PAPERRAG_AUTOMATIC_OCR_MIN_COVERAGE=0.9
FLAGS_use_mkldnn=0
PADDLE_PDX_ENABLE_MKLDNN_BYDEFAULT=False
PAPERRAG_PADDLE_LAYOUT_MODEL_NAME=PP-DocLayout-M
PAPERRAG_PADDLE_TEXT_DETECTION_MODEL_NAME=PP-OCRv5_mobile_det
PAPERRAG_PADDLE_TEXT_RECOGNITION_MODEL_NAME=korean_PP-OCRv5_mobile_rec
PAPERRAG_PADDLE_LAYOUT_MODEL_DIR=./models/paddlex/official_models/PP-DocLayout-M
PAPERRAG_PADDLE_TEXT_DETECTION_MODEL_DIR=./models/paddlex/official_models/PP-OCRv5_mobile_det
PAPERRAG_PADDLE_OCR_MODEL_DIR=./models/paddlex/official_models/korean_PP-OCRv5_mobile_rec
# 대형 셀 검출 모델이 필요하므로 기본값은 표 영역 OCR 텍스트 보존이다.
PAPERRAG_PADDLE_USE_TABLE_RECOGNITION=true
PAPERRAG_PADDLE_LAYOUT_THRESHOLD=0.3
PAPERRAG_PADDLE_LAYOUT_TEXT_RECONCILE=true
PAPERRAG_PADDLE_TEXT_COVERAGE_THRESHOLD=0.8
PAPERRAG_PADDLE_TEXT_MERGE_GAP_RATIO=1.8
PAPERRAG_PADDLE_ABSTRACT_MERGE_GAP_RATIO=0.5
PAPERRAG_PADDLE_ABSTRACT_MERGE_X_OVERLAP=0.7
PAPERRAG_FOOTNOTE_FILTER_ENABLED=true
PAPERRAG_FOOTNOTE_BOTTOM_RATIO=0.88
PAPERRAG_FOOTNOTE_MAX_HEIGHT_RATIO=0.02
PAPERRAG_FOOTNOTE_MAX_WIDTH_RATIO=0.5
PAPERRAG_FOOTNOTE_MAX_CHARS=240
PAPERRAG_PADDLE_TABLE_CLASSIFICATION_MODEL_DIR=./models/paddlex/official_models/PP-LCNet_x1_0_table_cls
PAPERRAG_PADDLE_WIRED_TABLE_MODEL_DIR=./models/paddlex/official_models/SLANeXt_wired
PAPERRAG_PADDLE_WIRELESS_TABLE_MODEL_DIR=./models/paddlex/official_models/SLANet_plus
PAPERRAG_PADDLE_TABLE_MIN_STRUCTURE_QUALITY=0.7
PAPERRAG_PAPER_COLLECTION_DIR=./data/inbox/collected
PAPERRAG_PAPER_COLLECTION_MANIFEST_NAME=collection-manifest.jsonl
PAPERRAG_PAPER_SMOKE_DIR=./data/inbox/smoke
PAPERRAG_PAPER_SMOKE_PAGES=1
PAPERRAG_PAPER_COLLECTION_QUERY=document layout analysis OCR
PAPERRAG_PAPER_COLLECTION_LIMIT=3
PAPERRAG_PAPER_COLLECTION_CANDIDATE_MULTIPLIER=5
PAPERRAG_PAPER_COLLECTION_ALLOWED_LICENSES=cc-by,cc-by-sa,cc0
PAPERRAG_PAPER_DOWNLOAD_MAX_MB=50
PAPERRAG_PAPER_COLLECTION_TIMEOUT_SECONDS=60
PAPERRAG_OPENALEX_BASE_URL=https://api.openalex.org
# https://openalex.org/settings/api 에서 무료 키 발급. 비워도 소량 익명 요청은 가능하지만 보장되지 않는다.
PAPERRAG_OPENALEX_API_KEY=
PAPERRAG_OPENALEX_CONTACT_EMAIL=
PAPERRAG_REDIS_URL=redis://localhost:6379/0
PAPERRAG_CELERY_BROKER_URL=redis://localhost:6379/0
PAPERRAG_CELERY_RESULT_BACKEND=redis://localhost:6379/1
PAPERRAG_SEARCH_SUGGESTION_LIMIT=3
PAPERRAG_SEARCH_SIMILARITY_THRESHOLD=0.5
PAPERRAG_RELATION_TOP_K=20
PAPERRAG_KEYWORD_ALIAS_SIMILARITY_THRESHOLD=0.95
PAPERRAG_PARAGRAPH_MIN_CHARS=100
PAPERRAG_PARAGRAPH_MAX_CHARS=1500
PAPERRAG_API_HOST=0.0.0.0
PAPERRAG_API_PORT=8000
PAPERRAG_API_BASE_URL=http://localhost:8000
PAPERRAG_PUBLIC_API_BASE_URL=http://localhost:8000
PAPERRAG_API_TIMEOUT_SECONDS=1800
PAPERRAG_LOG_LEVEL=INFO
